<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/center_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <!-- Stacked Label and Value Container -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <!-- Stacked Label Container (Left side of value) -->
            <LinearLayout
                android:id="@+id/lbl_stacked_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginRight="6dp"
                android:layout_marginEnd="6dp">

                <!-- Top text label -->
                <TextView
                    android:id="@+id/txt_halving_label_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false" />

                <!-- Separator line -->
                <FrameLayout
                    android:id="@+id/lbl_divider"
                    android:layout_width="16dp"
                    android:layout_height="1dp"
                    android:background="#E4E4E7"
                    android:layout_marginVertical="1.5dp" />

                <!-- Bottom text label -->
                <TextView
                    android:id="@+id/txt_halving_label_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Large Display Value -->
            <TextView
                android:id="@+id/txt_halving_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:letterSpacing="-0.02"
                android:maxLines="1"
                android:textColor="#E4E4E7"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Visual Progress Bar -->
        <TextView
            android:id="@+id/txt_halving_progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:textColor="#E4E4E7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Subtitle/Footer -->
        <TextView
            android:id="@+id/txt_halving_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:textColor="#8E8E93"
            android:textSize="8.5sp" />
    </LinearLayout>
</RelativeLayout>
