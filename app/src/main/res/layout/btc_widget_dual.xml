<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_dual"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="6dp"
    android:weightSum="2">

    <!-- Left Panel (Screen 1) -->
    <RelativeLayout
        android:id="@+id/left_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginEnd="4dp"
        android:layout_marginRight="4dp"
        android:background="@drawable/widget_background"
        android:padding="8dp">

        <!-- Center Display Layout (Left) -->
        <LinearLayout
            android:id="@+id/center_layout_left"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/footer_left"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <!-- Stacked Label Container (Left) -->
            <LinearLayout
                android:id="@+id/lbl_stacked_container_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginRight="6dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/txt_blockclock_label_top_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:includeFontPadding="false" />

                <FrameLayout
                    android:id="@+id/lbl_divider_left"
                    android:layout_width="16dp"
                    android:layout_height="1dp"
                    android:background="#E4E4E7"
                    android:layout_marginVertical="2dp" />

                <TextView
                    android:id="@+id/txt_blockclock_label_bottom_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Large Display Value (Left) -->
            <TextView
                android:id="@+id/txt_blockclock_value_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E4E4E7"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="-0.02"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Suffix Container (Left) -->
            <LinearLayout
                android:id="@+id/lbl_suffix_container_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginLeft="4dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/txt_blockclock_suffix_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- Footer (Left) -->
        <RelativeLayout
            android:id="@+id/footer_left"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btn_refresh_left"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txt_warning_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ "
                    android:textSize="9sp"
                    android:visibility="gone"
                    android:layout_marginEnd="2dp" />

                <TextView
                    android:id="@+id/txt_blockclock_sub_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="market price of btc"
                    android:textColor="#8E8E93"
                    android:textSize="8.5sp"
                    android:fontFamily="serif"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btn_refresh_left"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_refresh"
                android:padding="3dp"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>
    </RelativeLayout>

    <!-- Right Panel (Screen 2) -->
    <RelativeLayout
        android:id="@+id/right_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:layout_marginLeft="4dp"
        android:background="@drawable/widget_background"
        android:padding="8dp">

        <!-- Center Display Layout (Right) -->
        <LinearLayout
            android:id="@+id/center_layout_right"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/footer_right"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <!-- Stacked Label Container (Right) -->
            <LinearLayout
                android:id="@+id/lbl_stacked_container_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginRight="6dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/txt_blockclock_label_top_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:includeFontPadding="false" />

                <FrameLayout
                    android:id="@+id/lbl_divider_right"
                    android:layout_width="16dp"
                    android:layout_height="1dp"
                    android:background="#E4E4E7"
                    android:layout_marginVertical="2dp" />

                <TextView
                    android:id="@+id/txt_blockclock_label_bottom_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Large Display Value (Right) -->
            <TextView
                android:id="@+id/txt_blockclock_value_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E4E4E7"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="-0.02"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Suffix Container (Right) -->
            <LinearLayout
                android:id="@+id/lbl_suffix_container_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginLeft="4dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/txt_blockclock_suffix_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E4E4E7"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- Footer (Right) -->
        <RelativeLayout
            android:id="@+id/footer_right"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btn_refresh_right"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txt_warning_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ "
                    android:textSize="9sp"
                    android:visibility="gone"
                    android:layout_marginEnd="2dp" />

                <TextView
                    android:id="@+id/txt_blockclock_sub_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1$ per satoshis"
                    android:textColor="#8E8E93"
                    android:textSize="8.5sp"
                    android:fontFamily="serif"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btn_refresh_right"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_refresh"
                android:padding="3dp"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>
    </RelativeLayout>
</LinearLayout>
