<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="8dp">

        <!-- Center Display Layout (Horizontally aligning scaled label, value, and suffix) -->
        <LinearLayout
            android:id="@+id/center_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/footer"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

        <!-- Stacked Label Container (Left side of value) -->
        <LinearLayout
            android:id="@+id/lbl_stacked_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginRight="8dp">

            <!-- Top text label (e.g. BTC, MSCW, MSTR) -->
            <TextView
                android:id="@+id/txt_blockclock_label_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E4E4E7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textScaleX="0.8"
                android:includeFontPadding="false" />

            <!-- Separator line -->
            <FrameLayout
                android:id="@+id/lbl_divider"
                android:layout_width="24dp"
                android:layout_height="1dp"
                android:background="#E4E4E7"
                android:layout_marginVertical="2dp" />

            <!-- Bottom text label (e.g. USD, TIME, BTC) -->
            <TextView
                android:id="@+id/txt_blockclock_label_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E4E4E7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textScaleX="0.8"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- Large Display Value - Condensed to match the hardware screen -->
        <TextView
            android:id="@+id/txt_blockclock_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E4E4E7"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textScaleX="0.72"
            android:letterSpacing="-0.03"
            android:ellipsize="end"
            android:maxLines="1" />

        <!-- Suffix Container (Right side of value for MIL suffix) -->
        <LinearLayout
            android:id="@+id/lbl_suffix_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginLeft="6dp">

            <TextView
                android:id="@+id/txt_blockclock_suffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E4E4E7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textScaleX="0.8"
                android:includeFontPadding="false" />
        </LinearLayout>

    </LinearLayout>

    <!-- Footer with Dynamic Subtitle Centered -->
    <RelativeLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="4dp"
        android:layout_alignParentBottom="true">

        <!-- Subtitle displays dynamic short description in lowercase, centered horizontally -->
        <TextView
            android:id="@+id/txt_blockclock_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Market price of bitcoin"
            android:textColor="#8E8E93"
            android:textSize="9sp"
            android:fontFamily="sans-serif-condensed"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:gravity="center" />
    </RelativeLayout>
</RelativeLayout>
